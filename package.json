{
  "name": "claude-code-ppt-addin",
  "version": "1.0.0",
  "description": "Claude Code for PowerPoint — AI-powered Office JS add-in for manipulating shapes, charts, tables, masters, layouts, and themes",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "start": "webpack serve --mode development",
    "lint": "eslint src/**/*.ts",
    "cert": "office-addin-dev-certs install",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "css-loader": "^6.8.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.2",
    "office-addin-dev-certs": "^1.12.2",
    "office-addin-manifest": "^1.12.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  }
}
